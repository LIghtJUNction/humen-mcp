HUMEN_BIND=127.0.0.1:8787
HUMEN_PUBLIC_BASE_URL=https://your-domain.example/mcp
HUMEN_WEB_DIST=./humen-mcp-webui/dist
HUMEN_USERS_FILE=/var/lib/humen-mcp/users.json
HUMEN_ADMIN_EMAIL=<admin-email>
HUMEN_ADMIN_PASSWORD=change-me
HUMEN_SESSION_SECRET=change-this-to-a-long-random-secret
HUMEN_TRASH_RETENTION_SECONDS=604800
HUMEN_CLEANUP_INTERVAL_SECONDS=60
HUMEN_SELF_UPDATE_COMMAND=
HUMEN_SELF_UPDATE_TIMEOUT_SECONDS=120

# Optional GitHub OAuth login. The GitHub button is hidden unless both
# values are configured. Configure the callback URL as:
# https://your-domain.example/mcp/api/auth/oauth/github/callback
HUMEN_GITHUB_CLIENT_ID=
HUMEN_GITHUB_CLIENT_SECRET=

# Optional server-side GitHub API token for reputation seeding. This is used
# only for GitHub account metadata lookups and lets the server avoid the low
# unauthenticated API quota. Admins can also set it in the web UI.
HUMEN_GITHUB_API_TOKEN=
